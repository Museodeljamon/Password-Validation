import re
import ipywidgets as widgets
from IPython.display import display, clear_output, HTML # Import HTML

def validate_password(password):
    """
    Validates a password based on specified criteria.

    Args:
        password (str): The password string to validate.

    Returns:
        tuple: (bool, list of str) - True if valid, False otherwise, and a list of feedback messages.
    """
    is_valid = True
    feedback_messages = []

    # Length check character between 6-16
    if len(password) > 16:
        feedback_messages.append("Your password is too long la! 6 to 16!")
        return False, feedback_messages
    if len(password) < 6:
        feedback_messages.append("the length of your password is insufficient for our business, please use between 6 to 16 characters")
        return False, feedback_messages

    # Character type checks (only if length is between 6-16, already handled by early returns)
    # 1. At least 1 letter between [a-z] and 1 letter between [A-Z]
    if not re.search(r"[a-z]", password):
        feedback_messages.append("At least 1 letter between [a-z]")
        is_valid = False
    if not re.search(r"[A-Z]", password):
        feedback_messages.append("At least 1 letter between [A-Z]")
        is_valid = False

    # 2. At least 1 number between [0-9]
    if not re.search(r"[0-9]", password):
        feedback_messages.append("At least 1 number between [0-9]")
        is_valid = False

    # 3. At least 1 character from [!%^&*()$#@]
    if not re.search(r"[!%^&*()$#@]", password):
        feedback_messages.append("At least 1 character from [!%^&*()$#@]")
        is_valid = False

    return is_valid, feedback_messages


# Create a text input widget for the password
password_input = widgets.Text(
    value='',
    placeholder='Enter your password here',
    description='Password:',
    disabled=False,
    continuous_update=False # Validate only on Enter or when focus leaves
)

# Create a button widget
check_button = widgets.Button(
    description='Check Password',
    disabled=False,
    button_style='', # 'success', 'info', 'warning', 'danger' or ''
    tooltip='Click to validate password',
    icon='check'
)

# Output widget to display validation results
output_area = widgets.Output()

# State variables for tracking invalid password attempts
invalid_password_count = 0
last_invalid_password = ""

def on_button_click(b):
    global invalid_password_count
    global last_invalid_password

    with output_area:
        clear_output()
        password = password_input.value
        is_valid, feedback_messages = validate_password(password) # Call the modified function

        if is_valid:
            print("your password is valid")
            # Reset count and last password on successful validation
            invalid_password_count = 0
            last_invalid_password = ""
            # Display the continue button as an HTML link
            display(HTML('<a href="https://zombo.com/" target="_blank"><button>Continue</button></a>'))
        else:
            for msg in feedback_messages:
                print(f"- {msg}")

            # Check if the current invalid password is the same as the last one
            if password == last_invalid_password:
                invalid_password_count += 1
            else:
                invalid_password_count = 1 # Reset if a different invalid password is entered
                last_invalid_password = password

            if invalid_password_count >= 5:
                display(HTML('<a href="https://thisisnotajumpscare.com/" target="_blank"><button>Try the wrong password again from this button</button></a>'))

# Attach the event handler to the button
check_button.on_click(on_button_click)

# Display the widgets
display(HTML('<h2>Lazada Company</h2>'))
display(password_input, check_button, output_area)
